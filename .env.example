# Copy this file to .env and fill in your values

# Required: Google Gemini API key (server-side only — never exposed to the browser)
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: API port for local Express server (default 3001)
PORT=3001

# Optional: Supabase — for community data + ML model training
# Create a free project at https://supabase.com
# Run supabase-schema.sql then supabase-schema-ml.sql in the SQL editor

# Frontend (charts/dashboard — public anon key is fine)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server (ML training reads sessions table — use same anon key or service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  ← optional, for stricter RLS
